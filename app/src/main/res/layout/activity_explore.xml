<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Title & User Profile Mini -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/exploreTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black" />

                <androidx.cardview.widget.CardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#2C2C2C">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="8dp"
                        app:tint="#FFFFFF"/>
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <!-- Modern Search Bar -->
            <LinearLayout
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_modern"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#888888" />

                <EditText
                    android:id="@+id/editSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search trails, cities..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:paddingStart="12dp"
                    android:textSize="15sp"
                    android:inputType="text" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="#A5D6A7" />
            </LinearLayout>

            <!-- Category Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥 Popular" android:textColor="#000000" android:background="@drawable/btn_green_rounded" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_marginEnd="10dp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⛰️ Mountain" android:textColor="#FFFFFF" android:background="@drawable/bg_filter_chip" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌳 Forest" android:textColor="#FFFFFF" android:background="@drawable/bg_filter_chip" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏖️ Coastal" android:textColor="#FFFFFF" android:background="@drawable/bg_filter_chip" android:paddingHorizontal="16dp" android:paddingVertical="8dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nearby You"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginStart="20dp"
                android:fontFamily="sans-serif-medium"/>

            <LinearLayout
                android:id="@+id/exploreContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Trail Card Example 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTrail1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#121212"
                    android:layout_marginBottom="32dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Image Stack -->
                        <FrameLayout
                            android:id="@+id/imgContainer1"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/logo"
                                android:background="#1E1E1E"
                                android:contentDescription="Trail Image" />

                            <ImageButton
                                android:id="@+id/btnSaveTrail1"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="12dp"
                                android:background="@drawable/bg_search_bar"
                                android:src="@android:drawable/ic_menu_save"
                                app:tint="#FFFFFF"
                                android:padding="8dp"
                                android:contentDescription="Save" />

                            <!-- Map Preview -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_gravity="bottom|end"
                                android:layout_margin="12dp"
                                app:cardCornerRadius="12dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@android:drawable/ic_dialog_map"
                                    android:scaleType="centerCrop"
                                    android:background="#333333"
                                    android:contentDescription="Map Preview" />
                            </androidx.cardview.widget.CardView>

                            <!-- Indicators -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|center_horizontal"
                                android:layout_marginBottom="12dp"
                                android:orientation="horizontal">
                                <View android:layout_width="6dp" android:layout_height="6dp" android:background="#FFFFFF" android:layout_margin="2dp" />
                                <View android:layout_width="6dp" android:layout_height="6dp" android:background="#88FFFFFF" android:layout_margin="2dp" />
                                <View android:layout_width="6dp" android:layout_height="6dp" android:background="#88FFFFFF" android:layout_margin="2dp" />
                            </LinearLayout>

                        </FrameLayout>

                        <!-- Content below image -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:id="@+id/txtTrailName1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Castleton, Mam Tor, and Great Ridge"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="4dp">
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" android:contentDescription="Rating" />
                                <TextView android:id="@+id/txtSubInfo1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 4.7 • Moderate • Peak District National Park" android:textColor="#CCCCCC" android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Stats Row (Summary) -->
                            <TextView
                                android:id="@+id/txtStats1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12.9 km • 639 m • 4 hr"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Trail Card Example 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTrail2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#121212"
                    android:layout_marginBottom="32dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/imgContainer2"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img"
                                android:background="#1E1E1E"
                                android:contentDescription="Trail Image" />

                            <ImageButton
                                android:id="@+id/btnSaveTrail2"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="12dp"
                                android:background="@drawable/bg_search_bar"
                                android:src="@android:drawable/ic_menu_save"
                                app:tint="#FFFFFF"
                                android:padding="8dp"
                                android:contentDescription="Save" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">
                            <TextView
                                android:id="@+id/txtTrailName2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mount Pulunbato Loop"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txtSubInfo2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3.7 • Moderate • Zamboanga City"
                                android:textColor="#CCCCCC"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Trail Card Example 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTrail3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#121212"
                    android:layout_marginBottom="32dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/imgContainer3"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_1"
                                android:background="#1E1E1E"
                                android:contentDescription="Trail Image" />

                            <ImageButton
                                android:id="@+id/btnSaveTrail3"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="12dp"
                                android:background="@drawable/bg_search_bar"
                                android:src="@android:drawable/ic_menu_save"
                                app:tint="#FFFFFF"
                                android:padding="8dp"
                                android:contentDescription="Save" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">
                            <TextView
                                android:id="@+id/txtTrailName3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sibugay Peak Trail"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/txtSubInfo3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4.2 • Hard • Ipil, Zamboanga Sibugay"
                                android:textColor="#CCCCCC"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:gravity="center">
        <Button android:id="@+id/btnExplore" style="@style/BottomNavButton" android:text="Explore" android:drawableTop="@android:drawable/ic_menu_search" />
        <Button android:id="@+id/btnMap" style="@style/BottomNavButton" android:text="Map" android:drawableTop="@android:drawable/ic_dialog_map" />
        <Button android:id="@+id/btnSaved" style="@style/BottomNavButton" android:text="Saved" android:drawableTop="@android:drawable/ic_menu_save" />
        <Button android:id="@+id/btnProfile" style="@style/BottomNavButton" android:text="Profile" android:drawableTop="@android:drawable/ic_menu_myplaces" />
    </LinearLayout>

</RelativeLayout>