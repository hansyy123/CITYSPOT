<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#43523D"
    android:padding="24dp">

    <!-- App logo (small centered) -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="48dp"
        android:src="@drawable/logo"
        android:contentDescription="App Icon" />

    <!-- Title Text -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign up or log in to start exploring"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_below="@id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-medium" />

    <!-- Apple button container -->
    <LinearLayout
        android:id="@+id/btnApple"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/txtTitle"
        android:layout_marginTop="32dp"
        android:background="@drawable/btn_dark_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/apple"
            android:contentDescription="Apple Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue with Apple"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Google button container -->
    <LinearLayout
        android:id="@+id/btnGoogle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/btnApple"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_dark_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/google"
            android:contentDescription="Google Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue with Google"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Facebook button container -->
    <LinearLayout
        android:id="@+id/btnFacebook"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/btnGoogle"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_dark_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/facebook"
            android:contentDescription="Facebook Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue with Facebook"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Divider with "or" -->
    <LinearLayout
        android:id="@+id/layoutDivider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/btnFacebook"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="or"
            android:textColor="#FFFFFF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#FFFFFF" />
    </LinearLayout>

    <!-- Continue with Email Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/layoutDivider"
        android:layout_marginTop="24dp"
        android:text="Continue with email"
        android:textColor="#000000"
        android:background="@drawable/btn_light_rounded"
        android:backgroundTint="@null"
        android:textSize="16sp"
        android:textAllCaps="false"/>

</RelativeLayout>